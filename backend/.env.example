# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── App ───────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./jobhunt.db

# ── Scraping ──────────────────────────────────────────────
# Max concurrent scraper workers
SCRAPER_MAX_WORKERS=6
# Seconds to wait between requests per domain
SCRAPER_RATE_LIMIT_DELAY=2.0
# Max jobs to return per board per search
SCRAPER_MAX_RESULTS_PER_BOARD=25
# Default search location
DEFAULT_LOCATION=Canada

# ── Uploads ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
